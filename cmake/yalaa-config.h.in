#ifndef YALAA_CONFIG_H
#define YALAA_CONFIG_H

/*
 * All macros below follow #ifdef semantics (matching the source, which
 * tests them with #ifdef/#elif, not #if): each is either defined to 1, or
 * left completely undefined. Do not switch these to #cmakedefine01 -
 * defining an unselected backend to literal 0 would still satisfy #ifdef
 * and break the mutually-exclusive backend selection below.
 */
#cmakedefine YALAA_HAVE_CXSC 1
#cmakedefine YALAA_HAVE_FILIB 1
#cmakedefine YALAA_HAVE_PROFIL_BIAS 1
#cmakedefine YALAA_HAVE_CUSTOM_IV_LIB 1

#cmakedefine YALAA_HAVE_LONG_DOUBLE_WIDER 1

#endif /* YALAA_CONFIG_H */
