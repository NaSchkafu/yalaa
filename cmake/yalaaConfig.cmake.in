@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(YALAA_IV_BACKEND "@YALAA_IV_BACKEND@")

find_dependency(Boost 1.47)

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")
if(YALAA_IV_BACKEND STREQUAL "cxsc")
  find_dependency(CXSC 2.5.0)
elseif(YALAA_IV_BACKEND STREQUAL "filib")
  find_dependency(FILIB)
elseif(YALAA_IV_BACKEND STREQUAL "profil_bias")
  find_dependency(PROFIL_BIAS)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/yalaaTargets.cmake")
